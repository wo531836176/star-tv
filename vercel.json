{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "css/**",
      "use": "@vercel/static"
    },
    {
      "src": "lib/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server.js" },
    { "src": "/proxy/(.*)", "dest": "server.js" },
    { "src": "/parse-m3u8(.*)", "dest": "server.js" },
    { "src": "/download-start(.*)", "dest": "server.js" },
    { "src": "/download-status(.*)", "dest": "server.js" },
    { "src": "/download-cancel(.*)", "dest": "server.js" },
    { "src": "/download-clear-all(.*)", "dest": "server.js" },
    { "src": "/(.*)", "dest": "/" }
  ]
}
